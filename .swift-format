{
  "indentation": {
    "tabs": 1
  },
  "lineLength": 120,
  "maximumBlankLines": 1,
  "respectsExistingLineBreaks": true,
  "rules": {
    "AllPublicDeclarationsHaveDocumentation": false,
    "BeginDocumentationCommentWithOneLineSummary": false,
    "NoBlockComments": true,
    "OrderedImports": true,
    "UseTripleSlashForDocumentationComments": true
  }
}
